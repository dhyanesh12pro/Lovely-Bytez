# Required before production launch.
# Use the real domain after it is connected, for example:
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=

# Keep preview/staging blocked. Turn this on only for the real production domain.
NEXT_PUBLIC_ALLOW_INDEXING=false

# Optional emergency switch. If true, robots and meta robots block indexing.
NEXT_PUBLIC_INDEXING_DISABLED=false
